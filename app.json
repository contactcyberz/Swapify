{
  "expo": {
    "name": "Swapify",
    "slug": "swapify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#040F1E"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Swapify utilise ta localisation pour trouver des personnes près de toi.",
          "locationAlwaysPermission": "Swapify utilise ta localisation pour trouver des personnes près de toi.",
          "locationWhenInUsePermission": "Swapify utilise ta localisation pour trouver des personnes près de toi."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.swapify.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Swapify utilise la caméra pour ta photo de profil.",
        "NSPhotoLibraryUsageDescription": "Swapify accède à tes photos pour ta photo de profil.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.swapify.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#040F1E"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "c.touf",
    "extra": {
      "eas": {
        "projectId": "f82f9260-6a42-4dcb-b1f2-f356a10c8ac9"
      }
    }
  }
}
